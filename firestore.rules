rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlanMember(planData) {
      return isSignedIn() && planData.members[request.auth.uid] != null;
    }

    function canCreatePlan() {
      return isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members[request.auth.uid] != null;
    }

    function canSelfJoinPlan() {
      return isSignedIn()
        && resource.data.members[request.auth.uid] == null
        && request.resource.data.members[request.auth.uid] != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'lastModified'])
        && request.resource.data.members.diff(resource.data.members).addedKeys().hasOnly([request.auth.uid]);
    }

    function canUpdatePlanContent() {
      return isSignedIn()
        && isPlanMember(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['items', 'completed', 'completedAt', 'lastModified']);
    }

    function canInviteMemberToPlan() {
      return isSignedIn()
        && isPlanMember(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'lastModified'])
        && request.resource.data.members.diff(resource.data.members).removedKeys().size() == 0
        && request.resource.data.members.diff(resource.data.members).changedKeys().size()
          == request.resource.data.members.diff(resource.data.members).addedKeys().size()
        && request.resource.data.members.diff(resource.data.members).addedKeys().size() == 1;
    }

    function canRemoveMemberFromPlan() {
      return isSignedIn()
        && isPlanMember(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'lastModified'])
        && request.resource.data.members.diff(resource.data.members).addedKeys().size() == 0
        && request.resource.data.members.diff(resource.data.members).changedKeys().size()
          == request.resource.data.members.diff(resource.data.members).removedKeys().size()
        && request.resource.data.members.diff(resource.data.members).removedKeys().size() == 1
        && (
          resource.data.ownerId == request.auth.uid
          || request.resource.data.members.diff(resource.data.members).removedKeys().hasOnly([request.auth.uid])
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    match /plans/{planId} {
      allow read: if isPlanMember(resource.data);
      allow create: if canCreatePlan();
      allow update: if canUpdatePlanContent()
        || canInviteMemberToPlan()
        || canRemoveMemberFromPlan()
        || canSelfJoinPlan();
      allow delete: if isPlanMember(resource.data)
        && (resource.data.ownerId == request.auth.uid || resource.data.completed == true);
    }

    match /friendRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && request.resource.data.fromEmail is string
        && request.resource.data.fromName is string
        && request.resource.data.toEmail is string
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp;
      allow read: if isSignedIn()
        && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update: if isSignedIn()
        && resource.data.to == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && resource.data.status == 'pending'
        && (request.resource.data.status == 'accepted' || request.resource.data.status == 'declined');
      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members[0] != request.resource.data.members[1]
        && request.resource.data.createdAt is timestamp;
      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.members;
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.to is string
        && request.resource.data.to != request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.type is string
        && request.resource.data.status == 'pending';
      allow read: if isSignedIn() && resource.data.to == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.to == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && resource.data.status == 'pending'
        && request.resource.data.status == 'sent';
      allow delete: if false;
    }

    match /planInvites/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && exists(/databases/$(database)/documents/plans/$(request.resource.data.planId))
        && get(/databases/$(database)/documents/plans/$(request.resource.data.planId)).data.members[request.auth.uid] != null;
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['useCount'])
        && request.resource.data.useCount == resource.data.useCount + 1
        && (resource.data.expiresAt == null || resource.data.expiresAt > request.time)
        && (resource.data.maxUses == null || resource.data.useCount < resource.data.maxUses);
      allow delete: if false;
    }
  }
}
